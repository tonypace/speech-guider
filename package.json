{
  "name": "speech-guider",
  "version": "1.0.0",
  "description": "Pronunciation & Prosody Evaluator",
  "scripts": {
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:real": "playwright test tests/e2e/real/",
    "test:e2e:mocked": "playwright test tests/e2e/mocked/",
    "test:e2e:headed": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:py": "pytest",
    "lint": "npm run lint:js && npm run lint:py",
    "lint:js": "eslint '**/*.{js,mjs,cjs,jsx}'",
    "lint:py": "ruff check . && ruff format . --check",
    "typecheck": "mypy .",
    "format:py": "ruff format .",
    "check": "npm run lint && npm run typecheck && npm run test:run && npm run test:py",
    "tauri": "tauri",
    "dev": "./scripts/dev.sh"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/dom": "^10.4.1",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^8.57.1",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.8",
    "jsdom": "^29.0.1",
    "vitest": "^4.1.1"
  }
}
